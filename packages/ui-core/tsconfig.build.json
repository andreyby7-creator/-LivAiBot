{
  "compilerOptions": {
    "target": "ES2024",
    "lib": ["ES2024", "DOM", "DOM.Iterable"],
    "outDir": "./dist",
    "rootDir": "./src",
    "composite": true,
    "incremental": true,
    // ВАЖНО: build-info кладём в dist/, чтобы "чистая" сборка (CI/локально после rm -rf dist)
    // не могла случайно пропустить генерацию .d.ts из-за stale *.tsbuildinfo.
    "tsBuildInfoFile": "./dist/tsconfig.build.tsbuildinfo",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "resolveJsonModule": false,
    "declaration": true,
    "declarationDir": "./dist",
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "allowJs": false,
    "checkJs": false,
    "jsx": "preserve",
    "strict": true
  },
  "include": ["src"],
  "exclude": [
    "node_modules",
    "dist",
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "src/**/*.test.tsx",
    "src/**/*.spec.tsx",
    "test/**/*"
  ]
}
