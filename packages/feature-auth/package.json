{
  "name": "@livai/feature-auth",
  "version": "1.0.0",
  "description": "Authentication feature business logic and domain models",
  "repository": {
    "type": "git",
    "url": "https://github.com/livai/livai.git",
    "directory": "packages/feature-auth"
  },
  "bugs": {
    "url": "https://github.com/livai/livai/issues"
  },
  "homepage": "https://github.com/livai/livai/tree/main/packages/feature-auth#readme",
  "main": "./dist/esm/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "sideEffects": false,
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": "24.12.0",
    "pnpm": "10.28.2"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./src/domain/LoginRequest.js": {
      "types": "./src/domain/LoginRequest.ts",
      "import": "./src/domain/LoginRequest.ts"
    },
    "./src/domain/RegisterRequest.js": {
      "types": "./src/domain/RegisterRequest.ts",
      "import": "./src/domain/RegisterRequest.ts"
    },
    "./src/domain/index.js": {
      "types": "./src/domain/index.ts",
      "import": "./src/domain/index.ts"
    },
    "./src/effects/login.js": {
      "types": "./src/effects/login.ts",
      "import": "./src/effects/login.ts"
    },
    "./src/effects/login/index.js": {
      "types": "./src/effects/login/index.ts",
      "import": "./src/effects/login/index.ts"
    },
    "./src/effects/logout.js": {
      "types": "./src/effects/logout.ts",
      "import": "./src/effects/logout.ts"
    },
    "./src/effects/logout/index.js": {
      "types": "./src/effects/logout/index.ts",
      "import": "./src/effects/logout/index.ts"
    },
    "./src/effects/register.js": {
      "types": "./src/effects/register.ts",
      "import": "./src/effects/register.ts"
    },
    "./src/effects/register/index.js": {
      "types": "./src/effects/register/index.ts",
      "import": "./src/effects/register/index.ts"
    },
    "./src/effects/refresh.js": {
      "types": "./src/effects/refresh.ts",
      "import": "./src/effects/refresh.ts"
    },
    "./src/effects/refresh/index.js": {
      "types": "./src/effects/refresh/index.ts",
      "import": "./src/effects/refresh/index.ts"
    },
    "./src/effects/index.js": {
      "types": "./src/effects/index.ts",
      "import": "./src/effects/index.ts"
    },
    "./src/stores/index.js": {
      "types": "./src/stores/index.ts",
      "import": "./src/stores/index.ts"
    },
    "./src/types/index.js": {
      "types": "./src/types/index.ts",
      "import": "./src/types/index.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "build:types": "tsc -b tsconfig.build.json",
    "build:dev": "tsup --sourcemap --no-clean",
    "build:watch": "tsup --watch",
    "dev": "tsup --watch",
    "lint": "pnpm run lint:dev",
    "type-check": "tsc --noEmit",
    "test": "NODE_OPTIONS='--no-warnings' vitest",
    "test:watch": "vitest --watch",
    "test:ui": "NODE_OPTIONS='--no-warnings' vitest --ui",
    "test:coverage": "NODE_OPTIONS='--no-warnings' vitest run --coverage",
    "test:coverage:html": "NODE_OPTIONS='--no-warnings' vitest run --coverage --coverage.reporter=html",
    "test:coverage:watch": "NODE_OPTIONS='--no-warnings' vitest --coverage --watch",
    "test:ci": "NODE_OPTIONS='--no-warnings' vitest run --coverage",
    "clean": "rm -rf dist *.tsbuildinfo .eslintcache",
    "lint:dev": "ESLINT_MODE=dev eslint --config ../../eslint.config.mjs src",
    "lint:canary": "ESLINT_MODE=canary eslint --config ../../eslint.config.mjs src",
    "lint:canary:fix": "ESLINT_MODE=canary eslint --config ../../eslint.config.mjs src --fix",
    "check:deps": "cd ../.. && node scripts/check-circular-deps-monorepo.js",
    "ci:check": "pnpm run type-check && pnpm run lint && pnpm run test:ci && pnpm run check:deps",
    "lint:fix": "ESLINT_MODE=dev eslint --config ../../eslint.config.mjs src --fix",
    "lint:ci": "ESLINT_MODE=canary eslint --config ../../eslint.config.mjs src --max-warnings 0"
  },
  "keywords": [
    "typescript",
    "fp",
    "effect",
    "domain-driven-design",
    "contracts",
    "core",
    "foundation"
  ],
  "peerDependencies": {
    "effect": "^3.19.19",
    "typescript": "5.9.3",
    "zustand": "^5.0.11"
  },
  "peerDependenciesMeta": {
    "effect": {
      "optional": true
    },
    "zustand": {
      "optional": false
    }
  },
  "devDependencies": {
    "@livai/vitest-config": "workspace:*",
    "@vitest/coverage-v8": "4.0.18",
    "eslint": "9.39.3",
    "tsup": "8.5.1",
    "type-fest": "5.4.4",
    "typescript": "5.9.3",
    "vitest": "4.0.18"
  },
  "tags": [
    "node",
    "critical",
    "ui"
  ],
  "dependencies": {
    "@livai/app": "workspace:*",
    "@livai/core": "workspace:*",
    "@livai/core-contracts": "workspace:*",
    "@livai/domains": "workspace:*",
    "zod": "^4.3.6"
  },
  "optionalDependencies": {
    "lru-cache": "11.2.6"
  }
}
