{
  "name": "@livai/core",
  "version": "1.0.0",
  "description": "Core domain logic and business policies for LivAI platform",
  "repository": {
    "type": "git",
    "url": "https://github.com/livai/livai.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/livai/livai/issues"
  },
  "homepage": "https://github.com/livai/livai/tree/main/packages/core#readme",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": "24.12.0",
    "pnpm": "10.28.2"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./hash": {
      "types": "./dist/hash.d.ts",
      "import": "./dist/hash.js",
      "default": "./dist/hash.js"
    },
    "./feature-flags": {
      "types": "./dist/feature-flags/index.d.ts",
      "import": "./dist/feature-flags/index.js",
      "default": "./dist/feature-flags/index.js"
    },
    "./feature-flags/react": {
      "types": "./dist/feature-flags/react.d.ts",
      "import": "./dist/feature-flags/react.js",
      "default": "./dist/feature-flags/react.js"
    },
    "./domain-kit": {
      "types": "./dist/domain-kit/index.d.ts",
      "import": "./dist/domain-kit/index.js",
      "default": "./dist/domain-kit/index.js"
    },
    "./effect": {
      "types": "./dist/effect/index.d.ts",
      "import": "./dist/effect/index.js",
      "default": "./dist/effect/index.js"
    },
    "./effect/offline-cache": {
      "types": "./dist/effect/offline-cache.d.ts",
      "import": "./dist/effect/offline-cache.js",
      "default": "./dist/effect/offline-cache.js"
    },
    "./resilience": {
      "types": "./dist/resilience/index.d.ts",
      "import": "./dist/resilience/index.js",
      "default": "./dist/resilience/index.js"
    },
    "./policies/*": {
      "types": "./dist/policies/*.d.ts",
      "import": "./dist/policies/*.js"
    },
    "./input-boundary/*": {
      "types": "./dist/input-boundary/*.d.ts",
      "import": "./dist/input-boundary/*.js"
    },
    "./telemetry": {
      "types": "./dist/telemetry/index.d.ts",
      "import": "./dist/telemetry/index.js",
      "default": "./dist/telemetry/index.js"
    },
    "./telemetry/batch-core": {
      "types": "./dist/telemetry/batch-core.d.ts",
      "import": "./dist/telemetry/batch-core.js",
      "default": "./dist/telemetry/batch-core.js"
    },
    "./telemetry/client": {
      "types": "./dist/telemetry/client.d.ts",
      "import": "./dist/telemetry/client.js",
      "default": "./dist/telemetry/client.js"
    },
    "./transport": {
      "types": "./dist/transport/index.d.ts",
      "import": "./dist/transport/index.js",
      "default": "./dist/transport/index.js"
    },
    "./performance": {
      "types": "./dist/performance/index.d.ts",
      "import": "./dist/performance/index.js",
      "default": "./dist/performance/index.js"
    },
    "./performance/react": {
      "types": "./dist/performance/react.d.ts",
      "import": "./dist/performance/react.js",
      "default": "./dist/performance/react.js"
    },
    "./access-control": {
      "types": "./dist/access-control/index.d.ts",
      "import": "./dist/access-control/index.js",
      "default": "./dist/access-control/index.js"
    },
    "./access-control/route-permissions": {
      "types": "./dist/access-control/route-permissions.d.ts",
      "import": "./dist/access-control/route-permissions.js",
      "default": "./dist/access-control/route-permissions.js"
    }
  },
  "scripts": {
    "build": "pnpm run build:types && pnpm run build:js",
    "build:types": "tsc -b tsconfig.build.json",
    "build:js": "tsup && pnpm run build:react",
    "build:react": "mkdir -p dist/feature-flags dist/performance && pnpm exec esbuild src/feature-flags/react.tsx --bundle --format=esm --platform=neutral --target=es2024 --minify --sourcemap --outfile=dist/feature-flags/react.js --external:react && pnpm exec esbuild src/performance/react.tsx --bundle --format=esm --platform=neutral --target=es2024 --minify --sourcemap --outfile=dist/performance/react.js --external:react",
    "build:dev": "tsup --sourcemap --no-clean",
    "build:watch": "tsup --watch",
    "dev": "tsup --watch",
    "lint": "pnpm run lint:dev",
    "type-check": "tsc --noEmit",
    "test": "NODE_OPTIONS='--no-warnings' vitest",
    "test:watch": "vitest --watch",
    "test:ui": "NODE_OPTIONS='--no-warnings' vitest --ui",
    "test:coverage": "NODE_OPTIONS='--no-warnings' vitest run --coverage",
    "test:coverage:html": "NODE_OPTIONS='--no-warnings' vitest run --coverage --coverage.reporter=html",
    "test:coverage:watch": "NODE_OPTIONS='--no-warnings' vitest --coverage --watch",
    "test:ci": "NODE_OPTIONS='--no-warnings' vitest run --coverage",
    "clean": "rm -rf dist *.tsbuildinfo .eslintcache",
    "lint:dev": "ESLINT_MODE=dev eslint --config ../../eslint.config.mjs src",
    "lint:canary": "ESLINT_MODE=canary eslint --config ../../eslint.config.mjs src",
    "lint:canary:fix": "ESLINT_MODE=canary eslint --config ../../eslint.config.mjs src --fix",
    "check:deps": "cd ../.. && node scripts/check-circular-deps-monorepo.js",
    "ci:check": "pnpm run type-check && pnpm run lint && pnpm run test:ci && pnpm run check:deps",
    "lint:fix": "ESLINT_MODE=dev eslint --config ../../eslint.config.mjs src --fix",
    "lint:ci": "ESLINT_MODE=canary eslint --config ../../eslint.config.mjs src --max-warnings 0"
  },
  "keywords": [
    "typescript",
    "domain-driven-design",
    "business-logic",
    "policies",
    "core",
    "foundation",
    "auth",
    "security"
  ],
  "peerDependencies": {
    "effect": "^3.19.19",
    "typescript": "5.9.3"
  },
  "peerDependenciesMeta": {
    "effect": {
      "optional": true
    }
  },
  "devDependencies": {
    "@livai/vitest-config": "workspace:*",
    "@vitest/coverage-v8": "4.1.0",
    "esbuild": "0.27.4",
    "eslint": "9.39.4",
    "server-only": "^0.0.1",
    "tsup": "8.5.1",
    "typescript": "5.9.3",
    "vitest": "4.1.0"
  },
  "tags": [
    "node",
    "critical",
    "domain",
    "business-logic"
  ],
  "dependencies": {
    "@livai/core-contracts": "workspace:*"
  }
}
